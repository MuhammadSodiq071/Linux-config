alias syu='yay -Syu'
alias syyuu='yay -Syyuu'
alias S='sudo pacman -S'
alias yS='yay -S'
alias Ss='pacman -Ss'
alias ySs='yay -Ss'
alias Q='pacman -Q'
alias yQ='yay -Q'
alias R='sudo pacman -R'
alias yR='yay -R'
alias z='zsh'
alias cat='bat'
alias ssystemctl='sudo systemctl'
alias sv='sudoedit'
alias clock='tty-clock -s -c -C 4'
alias nf='fastfetch'
alias pf='fastfetch --config examples/10 --logo ~/.config/fastfetch/logo'
