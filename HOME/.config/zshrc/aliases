# System
alias touchpad-fix='xinput set-prop "SynPS/2 Synaptics TouchPad" "libinput Tapping Enabled" 1; xinput set-prop "SynPS/2 Synaptics TouchPad" "libinput Natural Scrolling Enabled" 1'
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'

